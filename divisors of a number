class Solution {
public:
    vector<int> divisors(int n) {
        vector<int> res={0};
        for(int i=1;i<n/2;i++)
        {
            if (n%i == 0)
            {
                 res.push_back(i);
                 if (i != n/i)
                    res.push_back(n/i);
            }
        }
        sort(res.begin(),res.end());
        return res;
    }
};
